Крок 3: Підключення модулів
cpp
// main.cpp — повний старт
#include "raylib.h"
#include "building.h"
#include "unit.h"
#include "morale.h"
#include "resources.h"

int rome_food = 200, rome_money = 100;
int carth_food = 150, carth_money = 200;

int main() {
    InitWindow(1024, 768, "Punic Wars: Castra");
    SetTargetFPS(60);

    FactionState rome_state, carth_state;

    while (!WindowShouldClose()) {
        // Оновлення стану
        rome_state.has_food   = rome_food > 0;
        rome_state.has_money  = rome_money > 0;
        rome_state.update(ROME);

        carth_state.has_food  = carth_food > 0;
        carth_state.has_money = carth_money > 0;
        carth_state.update(CARTHAGE);

        BeginDrawing();
        ClearBackground({34, 85, 34, 255});

        // HUD
        DrawText(TextFormat("ROME | Food: %d | Money: %d | Combat: %.0f%%",
            rome_food, rome_money, rome_state.combat_modifier * 100),
            10, 10, 16, WHITE);
        DrawText(TextFormat("CARTHAGE | Food: %d | Money: %d | Revolt: %s | Combat: %.0f%%",
            carth_food, carth_money,
            carth_state.revolt ? "YES" : "NO",
            carth_state.combat_modifier * 100),
            10, 30, 16, ORANGE);

        EndDrawing();
    }
    CloseWindow();
    return 0;
}
