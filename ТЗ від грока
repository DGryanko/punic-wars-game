5.3 Раби (обидві нації)
cpp
enum SlaveTask { HUNT, FISH, GATHER, FARM, CARRY_WATER };

struct Slave {
    int x, y, hp = 40;
    SlaveTask task;
    Faction owner;
    float efficiency = 0.7f;

    int collectResource() {
        switch(task) {
            case HUNT:        return 3;
            case FISH:        return 2;
            case GATHER:      return 1;
            case FARM:        return 4;
            case CARRY_WATER: return 0; // буфер моралі гарнізону
        }
        return 0;
    }
};
